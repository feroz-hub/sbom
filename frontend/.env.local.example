# Copy this file to .env.local and adjust for your environment.
# .env.local is gitignored and overrides both .env and .env.development.
#
# REQUIRED — base URL of the FastAPI backend. There is no hardcoded fallback
# in source code; the frontend will throw at startup if this is unset.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── HCL IAM OIDC Authentication ──────────────────────────────────────────────
# Set NEXT_PUBLIC_AUTH_ENABLED=true to enable OIDC login with HCL IAM.
# When false (default), the app runs in dev mode with a synthetic admin user.
NEXT_PUBLIC_AUTH_ENABLED=false

# OIDC issuer — the HCL IAM realm URL (e.g. https://iam.hcl.example.com/realms/sbom)
# NEXT_PUBLIC_HCL_IAM_ISSUER=

# OIDC client ID — the public client registered in HCL IAM
# NEXT_PUBLIC_HCL_IAM_CLIENT_ID=

# Post-login redirect URI — must match the registered redirect URI in HCL IAM
# NEXT_PUBLIC_HCL_IAM_REDIRECT_URI=http://localhost:3000/auth/callback

# Post-logout redirect URI
# NEXT_PUBLIC_HCL_IAM_POST_LOGOUT_URI=http://localhost:3000

# OIDC scopes to request (space-separated)
# NEXT_PUBLIC_HCL_IAM_SCOPES=openid profile email
