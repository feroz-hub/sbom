# SBOM Analyser Frontend — copy to .env.local and adjust for your environment.

# Backend API base URL (required)
NEXT_PUBLIC_API_URL=http://localhost:8000

# HCL IAM OIDC — set NEXT_PUBLIC_AUTH_ENABLED=true for production login
NEXT_PUBLIC_AUTH_ENABLED=false

# Issuer (Keycloak-compatible paths derived when explicit URLs omitted)
NEXT_PUBLIC_HCL_IAM_ISSUER=
NEXT_PUBLIC_HCL_IAM_CLIENT_ID=

# Explicit OIDC endpoints (optional — override issuer-derived defaults)
NEXT_PUBLIC_HCL_IAM_AUTHORIZATION_URL=
NEXT_PUBLIC_HCL_IAM_TOKEN_URL=
NEXT_PUBLIC_HCL_IAM_LOGOUT_URL=

# Redirect URIs
NEXT_PUBLIC_HCL_IAM_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_HCL_IAM_POST_LOGOUT_URI=http://localhost:3000

# OIDC scopes (default in code: openid profile email)
NEXT_PUBLIC_HCL_IAM_SCOPES=openid profile email roles
