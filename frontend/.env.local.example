# SBOM Analyser Frontend — copy to .env.local and adjust for your environment.

# Backend API base URL (required)
NEXT_PUBLIC_API_URL=http://localhost:8000

# HCL IAM OIDC — set NEXT_PUBLIC_AUTH_ENABLED=true for production login
NEXT_PUBLIC_AUTH_ENABLED=false

# Issuer (Keycloak-compatible paths derived when explicit URLs omitted)
# NEXT_PUBLIC_HCL_IAM_ISSUER=https://<hcl-iam-domain>/<issuer-path>
# NEXT_PUBLIC_HCL_IAM_CLIENT_ID=sbom-analyser-ui

# Explicit OIDC endpoints (optional — override issuer-derived defaults)
# NEXT_PUBLIC_HCL_IAM_AUTHORIZATION_URL=https://<hcl-iam-domain>/protocol/openid-connect/auth
# NEXT_PUBLIC_HCL_IAM_TOKEN_URL=https://<hcl-iam-domain>/protocol/openid-connect/token
# NEXT_PUBLIC_HCL_IAM_LOGOUT_URL=https://<hcl-iam-domain>/protocol/openid-connect/logout

# Redirect URIs
# NEXT_PUBLIC_HCL_IAM_REDIRECT_URI=http://localhost:3000/auth/callback
# NEXT_PUBLIC_HCL_IAM_POST_LOGOUT_URI=http://localhost:3000

# OIDC scopes (default: openid profile email)
# NEXT_PUBLIC_HCL_IAM_SCOPES=openid profile email
