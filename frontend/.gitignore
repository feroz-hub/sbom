# ─────────────────────────────────────────────────────────
#  SBOM Analyzer — Next.js Frontend .gitignore
# ─────────────────────────────────────────────────────────

# ── Next.js ───────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Dependencies ──────────────────────────────────────────
node_modules/

# ── Environment & secrets ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.local.example

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing ───────────────────────────────────────────────
coverage/
.nyc_output/

# ── Package managers ──────────────────────────────────────
.pnp
.pnp.js
.yarn/install-state.gz

# ── IDE / editor ──────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
