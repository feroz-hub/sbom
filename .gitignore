# ─────────────────────────────────────────────────────────
#  SBOM Analyzer — .gitignore
# ─────────────────────────────────────────────────────────

# ── Environment & secrets ─────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
.virtualenv/

# ── Database ──────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Logs ─────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── PDF reports (generated at runtime) ───────────────────
*.pdf

# ── IDE / editor ─────────────────────────────────────────
.vscode/
.idea/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# ── Testing & coverage ───────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ── OS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
$RECYCLE.BIN/
