# ─────────────────────────────────────────────────────────
#  SBOM Analyzer — Environment Configuration
#  Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────

# NVD API Key — strongly recommended.
#   Request one free at https://nvd.nist.gov/developers/request-an-api-key
#   Rate limits (https://nvd.nist.gov/developers/start-here#RateLimits):
#     without key:  5 requests / 30 s  (~6.0 s between calls, concurrency=2)
#     with key:    50 requests / 30 s  (~0.6 s between calls, concurrency=10)
#   On a typical 45-component SBOM this drops the NVD phase from ~8 min to <30 s.
NVD_API_KEY=

# Advanced NVD tuning (usually leave at defaults):
# NVD_REQUEST_DELAY_WITH_KEY_SECONDS=0.6
# NVD_REQUEST_DELAY_WITHOUT_KEY_SECONDS=6.0
# NVD_CONCURRENCY_WITH_KEY=10
# NVD_CONCURRENCY_WITHOUT_KEY=2
 
# GitHub Personal Access Token (for GitHub Security Advisory analysis)
# Requires read:packages and read:org scopes.
GITHUB_TOKEN=

# VulDB / VulnDB API key (for VulDB vulnerability intelligence)
# Register in your VulDB account and keep VULNDB_DETAILS=0 unless you want
# per-result detail credit consumption.
VULNDB_API_KEY=
# VULNDB_API_BASE_URL=https://vuldb.com/?api
# VULNDB_API_VERSION=3
# VULNDB_LIMIT=5
# VULNDB_DETAILS=false
# VULNDB_MAX_COMPONENTS=100

# Analysis sources to use (comma-separated). Options: NVD, OSV, GITHUB, VULNDB
ANALYSIS_SOURCES=NVD,OSV,GITHUB,VULNDB

# CORS allowed origins (comma-separated). Use * only for local dev.
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ── Authentication (Finding A) ─────────────────────────────────────────────
# Bearer-token authentication on every state-touching API endpoint.
#
#   none   = no auth (DEFAULT — fine for local dev only)
#   bearer = require `Authorization: Bearer <token>` (allowlist in API_AUTH_TOKENS)
#   jwt    = require `Authorization: Bearer <jwt>` validated with JWT_SECRET_KEY
#
# When set to "bearer", API_AUTH_TOKENS MUST be populated with at least one
# token (comma-separated allowlist). The server will REFUSE to start if
# API_AUTH_MODE=bearer and API_AUTH_TOKENS is empty.
API_AUTH_MODE=none
# API_AUTH_TOKENS=tok-replace-me-with-a-strong-random-string,tok-rotate-me

# Server settings
HOST=0.0.0.0
PORT=8000

# Database — PostgreSQL for local development and production.
DATABASE_URL=postgresql+psycopg://sbom:sbom@localhost:5432/sbom_analyser
# SQLite remains supported for isolated tests and emergency rollback only:
# DATABASE_URL=sqlite:////absolute/path/to/repo/sbom_api.db
# ALLOW_SQLITE=true
POSTGRES_USER=sbom
POSTGRES_PASSWORD=sbom
POSTGRES_DB=sbom_analyser
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# Redis / Celery (background analysis)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# Worker: celery -A app.workers.celery_app worker --loglevel=info

# JWT auth (alternative to bearer allowlist). Requires API_AUTH_MODE=jwt
# JWT_SECRET_KEY=
# JWT_ALGORITHM=HS256
# Optional claims:
# JWT_AUDIENCE=
# JWT_ISSUER=

# S3-compatible storage (optional — SBOM blobs / reports)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=
# AWS_S3_ENDPOINT_URL=

# Legacy analysis level (1=standard, 2=deep)
ANALYSIS_LEGACY_LEVEL=1

# ── API rate limiting (slowapi) ────────────────────────────────────────────
# Set to false for local tests or trusted single-user environments.
# API_RATE_LIMIT_ENABLED=true
# Default bucket for all routes (token bucket per client IP / bearer hash).
# API_RATE_LIMIT_DEFAULT=300/minute
# Stricter limit for POST …/analyze, …/analyze/stream, /analyze-sbom-*.
# API_RATE_LIMIT_ANALYZE=15/minute

# ── Idempotency-Key (POST analyze) ────────────────────────────────────────
# API_IDEMPOTENCY_ENABLED=true
# TTL in seconds for cached responses (default 86400 = 24h).
# API_IDEMPOTENCY_TTL_SECONDS=86400

# ── Shared httpx outbound client ─────────────────────────────────────────
# HTTPX_MAX_CONNECTIONS=100
# HTTPX_MAX_KEEPALIVE=20
# HTTPX_TIMEOUT_SECONDS=60
# Optional HTTP/2 (requires optional `h2` package): HTTPX_HTTP2=1

# ── Logging ────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO

# Log format: text (coloured console) | json (structured, good for log shippers)
LOG_FORMAT=text

# Log file path (optional — leave empty to log to console only)
# Rotating file handler: creates LOG_FILE, LOG_FILE.1, LOG_FILE.2, …
# LOG_FILE=logs/sbom.log

# Maximum size of each log file before rotation (MB, default: 10)
# LOG_MAX_MB=10

# Number of rotated backup files to keep (default: 5)
# LOG_BACKUPS=5
AI_FIXES_ENABLED=true
AI_FIXES_UI_CONFIG_ENABLED=true

# ── AI fix providers ─────────────────────────────────────────────────────────
# AI fixes need at least ONE provider with credentials, OR add one via the
# Settings → AI page (stored encrypted in the DB). A provider is only callable
# when its key/URL below is set. AI_DEFAULT_PROVIDER must name an enabled one.
AI_DEFAULT_PROVIDER=anthropic
# AI_PROVIDERS=anthropic,openai,gemini,grok,sarvam,ollama,vllm,custom_openai

# Anthropic (default provider) — set this to make AI fixes work out of the box.
ANTHROPIC_API_KEY=
# AI_ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI
OPENAI_API_KEY=
# AI_OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
# AI_GEMINI_MODEL=gemini-2.5-flash

# xAI Grok
GROK_API_KEY=
# AI_GROK_MODEL=grok-2-mini

# Sarvam AI (OpenAI-compatible — https://dashboard.sarvam.ai)
SARVAM_API_KEY=
# AI_SARVAM_MODEL=sarvam-m
# AI_SARVAM_BASE_URL=https://api.sarvam.ai/v1
# Lifecycle provider orchestration
LIFECYCLE_XEOL_ENABLED=false
LIFECYCLE_XEOL_API_URL=https://edb-prod.xeol.io/eol/check
LIFECYCLE_XEOL_API_KEY=
# JSON array; each record must include name/version (or cycle), lifecycle dates, and source_url.
LIFECYCLE_VENDOR_RECORDS_JSON=[]
