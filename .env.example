# ─────────────────────────────────────────────────────────
#  SBOM Analyzer — Environment Configuration
#  Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────

# NVD API Key (get one free at https://nvd.nist.gov/developers/request-an-api-key)
# Without a key, NVD rate-limits to 1 request per 6 seconds.
NVD_API_KEY=

# GitHub Personal Access Token (for GitHub Security Advisory analysis)
# Requires read:packages and read:org scopes.
GITHUB_TOKEN=

# Analysis sources to use (comma-separated). Options: NVD, OSV, GITHUB
ANALYSIS_SOURCES=NVD,OSV,GITHUB

# CORS allowed origins (comma-separated). Use * only for local dev.
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Server settings
HOST=0.0.0.0
PORT=8000

# SQLite database path (defaults to app/sbom_api.db)
# DATABASE_URL=sqlite:////absolute/path/to/sbom_api.db

# Legacy analysis level (1=standard, 2=deep)
ANALYSIS_LEGACY_LEVEL=1
